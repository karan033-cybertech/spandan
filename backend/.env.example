# Server
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS and email reset links)
FRONTEND_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://localhost:27017/spandan

# JWT Secret (generate a strong random string for production)
JWT_SECRET=your-super-secret-jwt-string-here

# AI Provider API Keys for Question Generation
MINIMAX_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# SMTP Email Configuration (for password reset & welcome emails)
# Using Gmail SMTP - enable 2FA and use App Password as SMTP_PASSWORD
SMTP_EMAIL=your@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# Optional: Resend API Key (alternative to Gmail SMTP)
RESEND_API_KEY=